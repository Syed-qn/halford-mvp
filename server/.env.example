# ─────────────────────────────────────────────────────────────────────────────
# Halford AI QS Workbench — environment configuration
# Copy to `.env` for local dev. On Render these are set in the dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# Autodesk Platform Services (formerly Forge) — https://aps.autodesk.com/
APS_CLIENT_ID=your_aps_client_id
APS_CLIENT_SECRET=your_aps_client_secret

# Optional: register a webhook so translation completions push to the server
# instead of being polled. Must be a public HTTPS URL — your Render hostname:
# APS_WEBHOOK_URL=https://halford.onrender.com/api/aps/webhooks/callback

# Anthropic Claude API — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─────────────────────────────────────────────────────────────────────────────
# Server / runtime
# ─────────────────────────────────────────────────────────────────────────────

# NODE_ENV=production            # Set on Render to enable secure cookies, etc.
PORT=3939

# Persistent storage. On Render, set DATA_DIR=/var/data so all stateful files
# (projects/, uploads/, output/, pdb-cache/) live on the mounted persistent disk
# and survive deploys. Locally, leave unset — files stay under server/.
# DATA_DIR=/var/data

# Optional Redis for the BullMQ job queue. If unset, jobs run inline in-process.
# REDIS_URL=redis://localhost:6379

# Optional Python solver sidecar (OR-Tools / IFC parsing). Unused by default.
# SOLVER_URL=http://localhost:8001
